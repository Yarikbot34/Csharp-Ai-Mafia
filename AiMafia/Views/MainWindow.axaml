<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AiMafia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AiMafia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AiMafia">

    <Design.DataContext>

        <vm:MainWindowViewModel/>
    </Design.DataContext>
    <Grid RowDefinitions="Auto, Auto, Auto, *">
        <ComboBox x:Name="ModelComboBox" 
                  Height="40"
                  ItemsSource="{Binding ViewAiModels}"
                  Margin="0,10,0,0"
                  PlaceholderText="Выберите модель...">
            
            <ComboBox.SelectionBoxItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding url}" 
                               FontWeight="SemiBold" 
                               FontSize="14"
                               VerticalAlignment="Center"/>
                </DataTemplate>
            </ComboBox.SelectionBoxItemTemplate>
            
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" 
                            BorderBrush="Gray" 
                            BorderThickness="1" 
                            CornerRadius="5"
                            Margin="0,2">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{Binding url}" 
                                       FontWeight="SemiBold" 
                                       FontSize="14"/>
                            <TextBlock Text="{Binding description}" 
                                       Foreground="Gray" 
                                       FontSize="12"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        <TextBox Grid.Row="1" x:Name="UserInput"/>
        <Button Grid.Row="2" Click="getAnswer"/>
        <TextBlock Grid.Row="3" Text="AiAnswer" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name = "AiAnswer"/>
    </Grid>
</Window>
