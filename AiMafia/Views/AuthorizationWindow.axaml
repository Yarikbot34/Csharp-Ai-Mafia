<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AiMafia.Views.AuthorizationWindow"
        Title="AuthorizationWindow">
    
        
        <StackPanel Margin="20" Spacing="15">
        
                <TextBlock Text="Введите данные:" FontWeight="SemiBold" />
                
                <TextBox Name="InputTextBox" Watermark="Введите текст..." />
                
                <CheckBox Name="OptionalCheckBox" Content="Включить дополнительную опцию" />
                
                <Button Name="ContinueButton" 
                        Content="Продолжить" 
                        HorizontalAlignment="Stretch" 
                        Click="OnContinueClick" />
                
                <TextBlock Name="ErrorTextBlock" Foreground="Red" TextWrapping="Wrap" />
        
        </StackPanel>
</Window>
